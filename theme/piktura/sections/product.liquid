        <div class="pk-details__grid">
          <div class="pk-details__artwork">
            <p class="pk-details__section-label">Approved artwork</p>
            <div class="pk-details__frame-wrap">
              <img data-details-artwork-img src="" alt="Generated artwork" class="pk-details__artwork-img">
            </div>
            <div class="pk-details__source-thumb">
              <img data-details-source-img src="" alt="Source upload">
              <p class="pk-details__source-label">Source photo</p>
            </div>
            <div class="pk-details__info-rows">
              <div class="pk-details__info-row">
                <span>Format</span><span>Hand-painted portrait</span>
              </div>
              <div class="pk-details__info-row">
                <span>Presentation</span><span data-details-frame-label>—</span>
              </div>
              <div class="pk-details__info-row">
                <span>Scale</span><span data-details-size-label>—</span>
              </div>
            </div>
          </div>

          {%- comment -%} Order summary {%- endcomment -%}
          <div class="pk-details__order">
            <p class="pk-details__section-label">Payment details</p>
            <h2 class="pk-details__order-title">Order summary</h2>

            <div class="pk-details__price-rows">
              <div class="pk-details__price-row">
                <span>Hand-painted portrait</span><span>{{ product.price | money }}</span>
              </div>
              <div class="pk-details__price-row">
                <span>Frame finishing</span><span>Included</span>
              </div>
              <div class="pk-details__price-row">
                <span>Protected shipping</span><span>Included</span>
              </div>
            </div>

            <div class="pk-details__total">
              <div>
                <p class="pk-details__section-label">Total</p>
                <p class="pk-details__total-price" data-details-price>{{ product.price | money }}</p>
              </div>
              <div class="pk-details__secure-badge">Secure checkout next</div>
            </div>

            <button type="button" class="pk-btn pk-btn--primary pk-btn--full" data-details-checkout-btn style="margin-top:1rem;padding:1rem;font-size:14px;display:flex;align-items:center;justify-content:center;gap:0.5rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
              Continue to Secure Payment
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>

            <button type="button" class="pk-btn pk-btn--ghost" data-details-back-btn style="width:100%;margin-top:0.75rem;font-size:14px;">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
              Back to Preview
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} Error message {%- endcomment -%}
  <p class="pk-error-text" data-error-message hidden role="alert"></p>
</div>

{%- comment -%} Variant data for JavaScript {%- endcomment -%}
<script type="application/json" data-variant-data>
[
  {%- for variant in product.variants -%}
    {
      "id": {{ variant.id }},
      "price": {{ variant.price | money_without_currency | json }},
      "price_formatted": {{ variant.price | money | json }},
      "compare_at_price": {% if variant.compare_at_price %}{{ variant.compare_at_price | money_without_currency | json }}{% else %}null{% endif %},
      "compare_at_price_formatted": {% if variant.compare_at_price %}{{ variant.compare_at_price | money | json }}{% else %}null{% endif %},
      "available": {{ variant.available | json }},
      "options": {
        {%- for opt in variant.options -%}
          {{ product.options[forloop.index0] | downcase | json }}: {{ opt | json }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      }
    }{% unless forloop.last %},{% endunless %}
  {%- endfor -%}
]
</script>

{%- comment -%} Style data for JS lookup {%- endcomment -%}
<script type="application/json" data-style-data>
[
  {%- assign _first_style = true -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'painting_style' -%}
    {%- unless _first_style -%},{%- endunless -%}
    {%- assign _jsi = '' -%}
    {%- case block.settings.style_key -%}
      {%- when 'classic', 'classic-oil' -%}{%- assign _jsi = 'style-classic.png' | asset_url -%}
      {%- when 'impressionist' -%}{%- assign _jsi = 'style-impressionist.png' | asset_url -%}
      {%- when 'warm', 'warm-painterly' -%}{%- assign _jsi = 'style-warm.png' | asset_url -%}
      {%- when 'minimal', 'modern-minimal' -%}{%- assign _jsi = 'style-minimal.png' | asset_url -%}
    {%- endcase -%}
    {
      "key": {{ block.settings.style_key | json }},
      "name": {{ block.settings.style_name | json }},
      "tone": {{ block.settings.style_tone | json }},
      "description": {{ block.settings.style_description | json }},
      "image": {{ _jsi | json }}
    }
    {%- assign _first_style = false -%}
    {%- endif -%}
  {%- endfor -%}
]
</script>

{%- comment -%} Frame data for JS lookup {%- endcomment -%}
<script type="application/json" data-frame-data>
[
  {%- assign _first_frame = true -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'frame_option' -%}
    {%- unless _first_frame -%},{%- endunless -%}
    {%- assign _jfi = '' -%}
    {%- case block.settings.frame_key -%}
      {%- when 'gold' -%}{%- assign _jfi = 'frame-gold.webp' | asset_url -%}
      {%- when 'antique-gold' -%}{%- assign _jfi = 'frame-antique-gold.webp' | asset_url -%}
      {%- when 'walnut' -%}{%- assign _jfi = 'frame-walnut.webp' | asset_url -%}
      {%- when 'natural-wood' -%}{%- assign _jfi = 'frame-natural-wood.webp' | asset_url -%}
      {%- when 'black' -%}{%- assign _jfi = 'frame-black.webp' | asset_url -%}
    {%- endcase -%}
    {
      "key": {{ block.settings.frame_key | json }},
      "name": {{ block.settings.frame_name | json }},
      "gradient": {{ block.settings.frame_gradient | json }},
      "image": {{ _jfi | json }}
    }
    {%- assign _first_frame = false -%}
    {%- endif -%}
  {%- endfor -%}
]
</script>

{%- comment -%} Room scene data {%- endcomment -%}
<script type="application/json" data-room-data>
[
  { "id": "gallery", "label": "Gallery Wall", "image": "{{ 'create_placeholder_option_b_20260628.png' | asset_url }}" }
]
</script>

{% comment %} Load customizer JS {% endcomment %}
<script src="{{ 'product-customizer.js' | asset_url }}" defer></script>

{% stylesheet %}
  /* Desktop/Mobile visibility */
  .pk-desktop-create { display: none; }
  .pk-mobile-create { display: block; }
  @media (min-width: 1024px) {
    .pk-desktop-create { display: flex; gap: 1.5rem; padding-top: 1rem; padding-bottom: 0; padding-left: 2rem; padding-right: 2rem; flex: 1; min-width: 0; max-width: 1600px; margin: 0 auto; width: 100%; align-items: stretch; }
    .pk-mobile-create { display: none; }
    .pk-create__canvas-area { height: auto; align-self: stretch; }
  }

  /* Step bar wrapper */
  .pk-step-bar-wrapper {
    border-bottom: 1px solid #E5E1D8;
    background: #F1EFE9;
  }
  .pk-step-bar-inner {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  @media (min-width: 768px) {
    .pk-step-bar-inner {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      position: relative;
      height: 52px;
      padding: 0 2rem;
    }
    .pk-step-bar__back {
      position: absolute;
      left: 2rem;
      top: 50%;
      transform: translateY(-58%);
    }
  }
  .pk-step-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    gap: 0;
    padding: 0;
    border: none;
    background: none;
  }

  @media (max-width: 1023px) {
    .pk-desktop-create { display: none; }
    .pk-step-bar-wrapper { display: none; }
  }
{% endstylesheet %}

