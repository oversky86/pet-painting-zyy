{% comment %}
  Piktura Product Customizer — Create Page
  Matches Create.tsx visual: sidebar (upload/style/size/frame) | canvas preview | summary panel.
  BUILD:v7-cdn-hardcoded
  Mobile: sticky preview + scrolling controls + fixed bottom CTA.

  Data attributes for JS: [data-customizer], [data-upload-zone], [data-style-grid], etc.
{% endcomment %}

<!-- PIKTURA_BUILD_v13 -->
{%- comment -%} Hidden file input for upload {%- endcomment -%}
<input
  type="file"
  accept="image/png,image/jpeg,image/webp"
  data-file-input
  class="sr-only"
  aria-hidden="true"
  tabindex="-1"
>

{%- comment -%} Desktop step bar {%- endcomment -%}
<div class="pk-step-bar-wrapper">
  <div class="pk-step-bar-inner">
    <a href="{{ routes.root_url }}" class="pk-back-btn pk-step-bar__back">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      <span>Back to Home</span>
    </a>
    <nav class="pk-step-bar" aria-label="Creation steps">
      <span class="pk-step-bar__step pk-step-bar__step--active" data-step-indicator="create">01 Create</span>
      <span class="pk-step-bar__sep" aria-hidden="true">—</span>
      <span class="pk-step-bar__step" data-step-indicator="preview">02 Preview</span>
      <span class="pk-step-bar__sep" aria-hidden="true">—</span>
      <span class="pk-step-bar__step" data-step-indicator="details">03 Details</span>
      <span class="pk-step-bar__sep" aria-hidden="true">—</span>
      <span class="pk-step-bar__step" data-step-indicator="checkout">04 Checkout</span>
    </nav>
  </div>
</div>

{%- comment -%} Main customizer {%- endcomment -%}
<div
  class="pk-create"
  data-customizer
  data-app-url="{{ settings.app_url }}"
  data-shop-domain="{{ shop.permanent_domain }}"
  data-use-real-generation="{{ settings.use_real_generation }}"
>
  {%- comment -%} ─── DESKTOP LAYOUT ─── {%- endcomment -%}
  <div class="pk-customizer-main" data-customizer-main>
  <div class="pk-desktop-create" style="flex:1;min-width:0;">

    {%- comment -%} Left: Sidebar controls {%- endcomment -%}
    <div class="pk-create__sidebar">
      <div class="pk-sidebar-card">

        {%- comment -%} 1. Upload {%- endcomment -%}
        <div class="pk-sidebar-section">
          <p class="pk-sidebar-label">1. Your Photo</p>
          <div class="pk-upload-zone" data-upload-zone role="button" tabindex="0" aria-label="Upload pet photo">
            <p class="pk-eyebrow-sm" style="text-align:center;">Studio Upload</p>
            <h4 style="margin-top:0.25rem;text-align:center;font-size:1.05rem;font-weight:600;color:#1a1a1a;">Upload Your Pet's Photo</h4>

            {%- comment -%} No upload state {%- endcomment -%}
            <div data-upload-empty>
              <button type="button" class="pk-upload-zone" data-upload-trigger style="margin-top:1rem;width:100%;">
                <div class="pk-upload-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
                </div>
                <p class="pk-upload-text">Start with one clear pet photo.</p>
              </button>
              <button type="button" class="pk-upload-btn" data-upload-trigger>browse files</button>
            </div>

            {%- comment -%} Uploaded state {%- endcomment -%}
            <div data-upload-preview hidden>
              <div class="pk-upload-preview">
                <div class="pk-upload-preview__overlay">
                  <img class="pk-upload-preview__img" data-upload-image src="" alt="Uploaded pet photo" loading="lazy" decoding="async">
                </div>
              </div>

              {%- comment -%} Generate button {%- endcomment -%}
              <button type="button" class="pk-btn pk-btn--generate pk-btn--full" data-generate-btn disabled style="margin-top:1rem;padding:0.75rem 1rem;gap:0.75rem;">
                <span style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,0.12);color:white;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.21 1.21 0 0 0 1.72 0L21.64 5.36a1.21 1.21 0 0 0 0-1.72Z"/><path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/></svg>
                </span>
                <span data-generate-label>Generate Preview</span>
              </button>

              <button type="button" class="pk-upload-change-btn" data-upload-change>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
                Change Photo
              </button>
            </div>

            <p class="pk-error-text" data-upload-error hidden role="alert"></p>
            <div aria-live="polite" class="sr-only" data-upload-status></div>
          </div>
        </div>

        <hr style="border:none;border-top:1px solid rgba(0,0,0,0.06);margin:0;">

        {%- comment -%} 2. Style {%- endcomment -%}
        <div class="pk-sidebar-section">
          <p class="pk-sidebar-label">2. Choose Style</p>
          <div class="pk-style-grid" role="radiogroup" aria-label="Painting style" data-style-grid>
            {%- for block in section.blocks -%}
              {%- if block.type == 'painting_style' -%}
                {%- assign _si = '' -%}
                {%- case block.settings.style_key -%}
                  {%- when 'classic', 'classic-oil' -%}{%- assign _si = 'style-classic.png' | asset_url -%}
                  {%- when 'impressionist' -%}{%- assign _si = 'style-impressionist.png' | asset_url -%}
                  {%- when 'warm', 'warm-painterly' -%}{%- assign _si = 'style-warm.png' | asset_url -%}
                  {%- when 'minimal', 'modern-minimal' -%}{%- assign _si = 'style-minimal.png' | asset_url -%}
                {%- endcase -%}
                <button
                  type="button"
                  class="pk-style-card"
                  role="radio"
                  aria-checked="false"
                  data-style-key="{{ block.settings.style_key }}"
                  data-style-image="{{ _si }}"
                  {{ block.shopify_attributes }}
                >
                  <div style="position:relative;overflow:hidden;">
                    {%- if _si != blank -%}
                      <img class="pk-style-card__img" src="{{ _si }}" alt="{{ block.settings.style_name }}" loading="lazy" decoding="async">
                    {%- else -%}
                      <div class="pk-style-card__img" style="background:#d4c4a8;display:flex;align-items:center;justify-content:center;aspect-ratio:4/3;">
                        <span style="font-size:2.5rem;" aria-hidden="true">&#127912;</span>
                      </div>
                    {%- endif -%}
                    <div class="pk-style-card__gradient"></div>
                    <div class="pk-style-card__check">
                      <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    </div>
                  </div>
                  <div class="pk-style-card__info">
                    <h4 class="pk-style-card__title">{{ block.settings.style_name }}</h4>
                  </div>
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        <hr style="border:none;border-top:1px solid rgba(0,0,0,0.06);margin:0;">

        {%- comment -%} 3. Size {%- endcomment -%}
        <div class="pk-sidebar-section">
          <p class="pk-sidebar-label">3. Size</p>
          <select class="pk-size-select" data-size-select>
            {%- assign has_size_option = false -%}
            {%- for option in product.options_with_values -%}
              {%- assign option_name_lower = option.name | downcase -%}
              {%- if option_name_lower == 'size' -%}
                {%- assign has_size_option = true -%}
                {%- for val in option.values -%}
                  <option value="{{ val }}" {%- if forloop.first %} selected{% endif %}>{{ val }}</option>
                {%- endfor -%}
              {%- endif -%}
            {%- endfor -%}
            {%- unless has_size_option -%}
              <option value="portrait-40x50" selected>Portrait · 40 x 50 cm</option>
              <option value="portrait-60x75">Portrait · 60 x 75 cm</option>
              <option value="landscape-75x60">Landscape · 75 x 60 cm</option>
              <option value="landscape-100x80">Landscape · 100 x 80 cm</option>
              <option value="square-60x60">Square · 60 x 60 cm</option>
              <option value="custom-size">Custom Size</option>
            {%- endunless -%}
          </select>
        </div>

        <hr style="border:none;border-top:1px solid rgba(0,0,0,0.06);margin:0;">

        {%- comment -%} 4. Frame {%- endcomment -%}
        <div class="pk-sidebar-section">
          <p class="pk-sidebar-label">4. Frame</p>
          <div class="pk-frame-grid" data-frame-grid>
            {%- for block in section.blocks -%}
              {%- if block.type == 'frame_option' -%}
                {%- assign _fi = '' -%}
                {%- case block.settings.frame_key -%}
                  {%- when 'gold' -%}{%- assign _fi = 'frame-gold.webp' | asset_url -%}
                  {%- when 'antique-gold' -%}{%- assign _fi = 'frame-antique-gold.webp' | asset_url -%}
                  {%- when 'walnut' -%}{%- assign _fi = 'frame-walnut.webp' | asset_url -%}
                  {%- when 'natural-wood' -%}{%- assign _fi = 'frame-natural-wood.webp' | asset_url -%}
                  {%- when 'black' -%}{%- assign _fi = 'frame-black.webp' | asset_url -%}
                {%- endcase -%}
                <button
                  type="button"
                  class="pk-frame-card"
                  data-frame-key="{{ block.settings.frame_key }}"
                  data-frame-gradient="{{ block.settings.frame_gradient }}"
                  {{ block.shopify_attributes }}
                >
                  <div style="position:relative;overflow:hidden;">
                    {%- if _fi != blank -%}
                      <img class="pk-frame-card__img" src="{{ _fi }}" alt="{{ block.settings.frame_name }}" loading="lazy" decoding="async">
                    {%- else -%}
                      <div class="pk-frame-card__img" style="background:{{ block.settings.frame_gradient }};aspect-ratio:4/3;"></div>
                    {%- endif -%}
                    <div class="pk-frame-card__check">
                      <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    </div>
                  </div>
                  <div class="pk-frame-card__label">{{ block.settings.frame_name }}</div>
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

      </div>
    </div>

    {%- comment -%} Center: Canvas Preview Area {%- endcomment -%}
    <div class="pk-create__canvas-area" data-preview-container style="position:relative;min-height:400px;padding:3rem;display:flex;align-items:center;justify-content:center;overflow:visible;background-color:#f7efdf;background-image:linear-gradient(180deg,#fcf7ee 0%,#f7ecd9 48%,#f0e0c2 100%);flex:1;align-self:stretch;">
      <div style="position:absolute;inset:0;background:radial-gradient(circle at 24% 24%,rgba(255,252,245,0.72),transparent 34%),radial-gradient(circle at 74% 34%,rgba(233,209,163,0.18),transparent 40%),linear-gradient(180deg,rgba(255,251,242,0.16),rgba(230,204,156,0.12));pointer-events:none;"></div>
      {%- comment -%} Canvas view {%- endcomment -%}
      <div data-canvas-view style="position:relative;width:100%;display:flex;justify-content:center;">
        <div class="pk-frame pk-frame--aspect-portrait" data-preview-frame style="width:min(62%, 572px);margin:0 auto;">
          {%- comment -%} Frame texture overlay {%- endcomment -%}
          <div class="pk-frame__texture" data-frame-texture></div>
          <div class="pk-frame__sheen"></div>
          <div class="pk-frame__inner-sheen"></div>
          <div class="pk-frame__inner-border">
            <div class="pk-frame__inner-frame">
              <div class="pk-frame__mat">
                <div class="pk-frame__canvas" data-canvas-area>
                  {%- comment -%} Empty placeholder {%- endcomment -%}
                  <div class="pk-canvas-placeholder" data-preview-empty>
                    <div class="pk-canvas-placeholder__inner">
                      <img src="{{ 'create_placeholder_option_b_20260628.png' | asset_url }}" alt="Quiet canvas illustration" style="width:152px;max-width:44%;height:auto;margin:0 auto;display:block;" loading="lazy" decoding="async">
                      <div class="pk-canvas-placeholder__divider"></div>
                      <p class="pk-canvas-placeholder__label">Quiet Canvas State</p>
                      <p class="pk-canvas-placeholder__title">Awaiting the first brushstroke</p>
                      <p class="pk-canvas-placeholder__desc">The frame stays intentionally calm so the generation moment feels more dramatic.</p>
                    </div>
                  </div>

                  {%- comment -%} Uploaded reference (blurred) {%- endcomment -%}
                  <div data-preview-reference hidden style="position:absolute;inset:0;">
                    <img data-reference-image src="" alt="Uploaded reference" style="width:100%;height:100%;object-fit:cover;transform:scale(1.04);filter:blur(4px) saturate(0.82) brightness(1.04) contrast(0.94);">
                    <div class="pk-ref-overlay">
                      <div class="pk-ref-overlay__badge">
                        <div class="pk-ref-overlay__badge-inner">Reference Loaded</div>
                      </div>
                      <div class="pk-ref-overlay__hint">
                        <div class="pk-ref-overlay__hint-inner">
                          <p class="pk-ref-overlay__hint-label">Next step</p>
                          <p class="pk-ref-overlay__hint-text">Choose a style, then generate your first preview.</p>
                        </div>
                      </div>
                    </div>
                  </div>

                  {%- comment -%} Generated result {%- endcomment -%}
                  <img data-preview-image src="" alt="" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform 0.7s;display:none;" hidden>

                  <div style="position:absolute;inset:0;box-shadow:inset 0 0 0 1px rgba(67,46,23,0.12),inset 0 18px 24px rgba(255,255,255,0.04),inset 0 -10px 18px rgba(0,0,0,0.04);pointer-events:none;"></div>
                </div>
              </div>
            </div>
          </div>
          <div style="position:absolute;left:22px;right:22px;top:11px;height:1px;background:linear-gradient(90deg,transparent,rgba(255,249,238,0.26),rgba(168,138,102,0.14),transparent);pointer-events:none;z-index:1;"></div>
          <div style="position:absolute;left:14px;right:14px;bottom:8px;height:32px;background:linear-gradient(to bottom,transparent,rgba(90,68,46,0.04),rgba(54,39,26,0.12));pointer-events:none;z-index:1;"></div>

          {%- comment -%} Generation overlay {%- endcomment -%}
          <div class="pk-gen-overlay" data-preview-generating hidden>
            <video class="pk-gen-overlay__video" src="{{ 'generation-motion-graphics.mp4' | asset_url }}" autoplay loop muted playsinline></video>
            <div class="pk-gen-overlay__bg"></div>
            <div class="pk-gen-overlay__card">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:0.75rem;">
                <div style="min-width:0;flex:1;">
                  <p class="pk-gen-overlay__label">Generation Progress</p>
                  <p class="pk-gen-overlay__title">Your portrait is taking shape.</p>
                  <p class="pk-gen-overlay__phase" data-generation-phase>Sketching silhouette and expression</p>
                </div>
                <div class="pk-gen-overlay__percent" data-progress-text>0%</div>
              </div>
              <div style="margin-top:0.75rem;">
                <div class="pk-gen-overlay__progress-label">
                  <span>Studio in progress</span>
                </div>
                <div class="pk-gen-overlay__progress-bar">
                  <div class="pk-gen-overlay__progress-fill" data-progress-fill role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" style="width:0%;"></div>
                  <div class="pk-gen-shimmer"></div>
                </div>
              </div>
            </div>
            <div class="pk-gen-overlay__glow"></div>
          </div>
        </div>
      </div>

      {%- comment -%} Room view (hidden by default) {%- endcomment -%}
      <div class="pk-room-view" data-room-view hidden>
        <img class="pk-room-view__bg" src="" data-room-image alt="Room background">
        <div class="pk-room-view__artwork" data-room-artwork style="top:22%;width:20%;min-width:200px;max-width:300px;left:57%;">
          <div class="pk-frame pk-frame--aspect-portrait" data-room-frame>
            <div class="pk-frame__texture" data-room-frame-texture></div>
            <div class="pk-frame__sheen"></div>
            <div class="pk-frame__inner-sheen"></div>
            <div class="pk-frame__inner-border">
              <div class="pk-frame__inner-frame">
                <div class="pk-frame__mat">
                  <div class="pk-frame__canvas">
                    <img data-room-canvas-image src="" alt="Canvas in room" style="width:100%;height:100%;object-fit:cover;">
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {%- comment -%} View toggle (appears after generation) {%- endcomment -%}
      <div data-view-toggle hidden style="position:absolute;bottom:1.5rem;left:50%;transform:translateX(-50%);z-index:10;">
        <div class="pk-view-toggle">
          <button type="button" class="pk-view-toggle__btn pk-view-toggle__btn--active" data-view-btn="canvas">Canvas</button>
          <button type="button" class="pk-view-toggle__btn" data-view-btn="room">Room</button>
        </div>
      </div>

      <div aria-live="polite" class="sr-only" data-preview-status></div>
    </div>

    {%- comment -%} Right: Summary Panel (shown after generation) {%- endcomment -%}
    <div class="pk-create__summary" data-summary-panel hidden>
      <div class="pk-summary-card">
        <h3 class="pk-summary-card__title">Your Selections</h3>

        <dl style="display:flex;flex-direction:column;gap:0.75rem;font-size:14px;">
          <div class="pk-summary-card__row">
            <dt>Style</dt>
            <dd data-summary-style>—</dd>
          </div>
          <div class="pk-summary-card__row">
            <dt>Size</dt>
            <dd data-summary-size>—</dd>
          </div>
          <div class="pk-summary-card__row">
            <dt>Frame</dt>
            <dd data-summary-frame>—</dd>
          </div>
          <div class="pk-summary-card__row">
            <dt>Preview</dt>
            <dd data-summary-preview>Not started</dd>
          </div>
        </dl>

        <div class="pk-summary-card__price">
          <span class="pk-summary-card__price-label">All-in Price</span>
          <span class="pk-summary-card__price-value" data-summary-price>{{ product.price | money }}</span>
        </div>
        <p class="pk-summary-card__includes" data-summary-compare hidden></p>
        <p class="pk-summary-card__includes">Includes AI preview, painting, & shipping.</p>

        {% comment %} Selling Plan (Deposit) Options {% endcomment %}
        {% if product.selling_plan_groups.size > 0 %}
          <fieldset class="pk-selling-plan" style="border:none;padding:0;margin:0.75rem 0 0;">
            <legend style="font-weight:600;font-size:14px;margin-bottom:8px;color:var(--pk-text, #2a2a2a);">Payment Options</legend>
            <label style="display:flex;align-items:center;gap:8px;padding:8px 12px;border:1px solid var(--pk-border, #e0e0e0);border-radius:8px;margin-bottom:6px;cursor:pointer;font-size:14px;" class="pk-selling-plan-option" data-plan-option="">
              <input type="radio" name="selling_plan" value="" style="accent-color:var(--pk-accent, #8b6e4e);">
              <span>Pay in full — <span data-full-price>{{ product.price | money }}</span></span>
            </label>
            {% for group in product.selling_plan_groups %}
              {% for plan in group.selling_plans %}
                {% assign deposit_pct = plan.checkout_charge.value %}
                <label style="display:flex;align-items:center;gap:8px;padding:8px 12px;border:1px solid var(--pk-accent, #8b6e4e);border-radius:8px;margin-bottom:6px;cursor:pointer;font-size:14px;background:rgba(139,110,78,0.06);" class="pk-selling-plan-option pk-selling-plan-option--active" data-plan-option="{{ plan.id }}">
                  <input type="radio" name="selling_plan" value="{{ plan.id }}" checked style="accent-color:var(--pk-accent, #8b6e4e);">
                  <span data-deposit-label data-deposit-pct="{{ deposit_pct }}" data-plan-name="{{ plan.name }}">{{ plan.name }} — Pay {{ deposit_pct }}% now, balance on shipment</span>
                </label>
              {% endfor %}
            {% endfor %}
          </fieldset>
        {% endif %}

        <div style="display:flex;flex-direction:column;gap:0.75rem;margin-top:0.5rem;">
          <button type="button" class="pk-btn pk-btn--primary pk-btn--full button-lift" data-checkout-btn disabled style="padding:1rem;font-size:16px;box-shadow:0 12px 24px rgba(49,39,31,0.12);">
            Continue to Details
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.7;transform:rotate(-90deg);"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <button type="button" class="pk-btn pk-btn--ghost" data-save-later style="width:100%;font-size:14px;">Save for later</button>
        </div>

        <div class="pk-summary-card__trust">
          <div class="pk-summary-card__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            <span>Free AI preview & revisions</span>
          </div>
          <div class="pk-summary-card__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            <span>Hand-painted by real artists</span>
          </div>
          <div class="pk-summary-card__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            <span>Museum-quality materials</span>
          </div>
          <div class="pk-summary-card__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
