{% comment %}
  Piktura Footer
  Brand, link columns, newsletter, copyright.
  Matches visual: Footer.tsx
{% endcomment %}

<footer class="pk-footer">
  <div class="pk-footer__inner">

    {% comment %} Brand column {% endcomment %}
    <div class="pk-footer__brand">
      <h2 class="pk-footer__brand-name">Piktura</h2>
      <p class="pk-footer__tagline">{{ section.settings.tagline }}</p>
    </div>

    {% comment %} Link columns {% endcomment %}
    {% for block in section.blocks %}
      {% if block.type == 'link_column' %}
        <div class="pk-footer__column" {{ block.shopify_attributes }}>
          <h3 class="pk-footer__column-title">{{ block.settings.heading }}</h3>
          <ul class="pk-footer__links">
            {% for link in block.settings.menu.links %}
              <li>
                <a href="{{ link.url }}" class="pk-footer__link">{{ link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    {% endfor %}

    {% comment %} Newsletter {% endcomment %}
    {% if section.settings.show_newsletter %}
      <div class="pk-footer__newsletter">
        <h3 class="pk-footer__column-title">{{ section.settings.newsletter_heading }}</h3>
        <p class="pk-footer__newsletter-text">{{ section.settings.newsletter_text }}</p>
        <form class="pk-footer__newsletter-form" action="{{ routes.contact_url }}" method="post">
          <input
            type="email"
            name="contact[email]"
            placeholder="{{ section.settings.newsletter_placeholder }}"
            class="pk-input pk-footer__newsletter-input"
            required
            aria-label="{{ section.settings.newsletter_placeholder }}"
          >
          <button type="submit" class="pk-btn pk-btn--primary pk-footer__newsletter-btn">
            {{ section.settings.newsletter_button }}
          </button>
        </form>
      </div>
    {% endif %}
  </div>

  <div class="pk-footer__bottom">
    <p>&copy; {{ 'now' | date: '%Y' }} Piktura. All rights reserved.</p>
  </div>
</footer>

{% stylesheet %}
  .pk-footer {
    width: 100%;
    border-top: 1px solid var(--pk-warm-border);
    background: var(--pk-cream-light);
    padding: 4rem 1.5rem 3rem;
    color: var(--pk-inverted);
  }
  .pk-footer__inner {
    max-width: 1600px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 768px) {
    .pk-footer__inner { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1024px) {
    .pk-footer__inner { grid-template-columns: 4fr 2fr 2fr 4fr; gap: 2rem; }
  }

  /* Brand */
  .pk-footer__brand-name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 1rem;
  }
  .pk-footer__tagline {
    font-size: 0.875rem;
    opacity: 0.6;
    max-width: 20rem;
  }

  /* Columns */
  .pk-footer__column-title {
    font-family: var(--font-heading);
    font-weight: 600;
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }
  .pk-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .pk-footer__link {
    font-size: 0.875rem;
    opacity: 0.6;
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .pk-footer__link:hover { opacity: 1; }

  /* Newsletter */
  .pk-footer__newsletter-text {
    font-size: 0.875rem;
    opacity: 0.6;
    margin-bottom: 1.5rem;
    max-width: 20rem;
    line-height: 1.6;
  }
  .pk-footer__newsletter-form {
    display: flex;
    gap: 0.5rem;
  }
  .pk-footer__newsletter-input {
    flex: 1;
    background: #F4ECDD;
    border-color: var(--pk-warm-border);
  }
  .pk-footer__newsletter-btn {
    white-space: nowrap;
    padding: 0.75rem 1.5rem;
  }

  /* Bottom */
  .pk-footer__bottom {
    max-width: 1600px;
    margin: 4rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--pk-warm-border);
    font-size: 0.75rem;
    opacity: 0.5;
  }

  footer {
    display: flex;
    justify-content: space-between;
    margin-top: 2rem;
  }
  footer a {
    text-decoration: none;
    color: var(--color-foreground);
  }
  footer .footer__links,
  footer .footer__payment {
    display: flex;
    gap: 1rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "See Your Pet as a Painting — Before You Pay"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "$10 off your first order"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter description",
      "default": "Join our family of pet lovers and get exclusive offers."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email placeholder",
      "default": "Email address"
    },
    {
      "type": "text",
      "id": "newsletter_button",
      "label": "Newsletter button text",
      "default": "Join"
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "link_column",
          "settings": { "heading": "Company" }
        },
        {
          "type": "link_column",
          "settings": { "heading": "Support" }
        }
      ]
    }
  ]
}
{% endschema %}
