{% comment %}
  Piktura Header
  Fixed navbar with brand, navigation, cart icon, and CTA button.
  Matches visual: Navbar.tsx
{% endcomment %}

<nav class="pk-header" data-header>
  <div class="pk-header__inner">

    {% comment %} Left: Mobile menu + Brand {% endcomment %}
    <div class="pk-header__left">
      <button
        type="button"
        class="pk-header__menu-btn pk-header__menu-btn--mobile"
        data-mobile-menu-toggle
        aria-label="{{ 'header.open_menu' | t }}"
        aria-expanded="false"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <a href="{{ routes.root_url }}" class="pk-header__brand">
        Piktura
      </a>
    </div>

    {% comment %} Center: Desktop navigation {% endcomment %}
    <ul class="pk-header__nav">
      {% for link in section.settings.menu.links %}
        <li>
          <a
            href="{{ link.url }}"
            class="pk-header__nav-link{% if link.active %} pk-header__nav-link--active{% endif %}"
          >
            {{ link.title }}
          </a>
        </li>
      {% endfor %}
    </ul>

    {% comment %} Right: Actions {% endcomment %}
    <div class="pk-header__right">
      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" class="pk-header__icon" aria-label="{{ 'header.account' | t }}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
      {% endif %}

      <a href="{{ routes.cart_url }}" class="pk-header__icon pk-header__cart" aria-label="{{ 'header.cart' | t }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        {% if cart.item_count > 0 %}
          <span class="pk-header__cart-badge" aria-label="{{ cart.item_count }} items"></span>
        {% endif %}
      </a>

      <a href="{{ routes.root_url }}#create" class="pk-btn pk-btn--primary pk-header__cta">
        {{ section.settings.cta_label }}
      </a>
    </div>
  </div>

  {% comment %} Mobile menu overlay {% endcomment %}
  <div class="pk-mobile-menu" data-mobile-menu>
    <ul class="pk-mobile-menu__nav">
      {% for link in section.settings.menu.links %}
        <li>
          <a href="{{ link.url }}" class="pk-mobile-menu__link{% if link.active %} pk-mobile-menu__link--active{% endif %}">
            {{ link.title }}
          </a>
        </li>
      {% endfor %}
    </ul>
    <a href="{{ routes.root_url }}#create" class="pk-btn pk-btn--primary pk-btn--full pk-mobile-menu__cta">
      {{ section.settings.cta_label }}
    </a>
  </div>
</nav>

{% stylesheet %}
  .pk-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 40;
    border-bottom: 1px solid var(--pk-warm-border);
    background: rgba(246,240,231,0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: all 0.3s;
  }
  .pk-header__inner {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .pk-header__left {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex: 1;
  }
  .pk-header__menu-btn {
    background: none;
    border: none;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s;
    padding: 0;
    display: flex;
    align-items: center;
  }
  .pk-header__menu-btn:hover { opacity: 1; }
  .pk-header__menu-btn--mobile { display: flex; }
  @media (min-width: 768px) {
    .pk-header__menu-btn--mobile { display: none; }
  }
  .pk-header__brand {
    font-size: 1.25rem;
    font-weight: 600;
    font-family: var(--font-heading);
    color: var(--pk-brown-dark);
    text-decoration: none;
  }
  @media (min-width: 768px) {
    .pk-header__brand { font-size: 1.5rem; }
  }

  /* Desktop nav */
  .pk-header__nav {
    display: none;
    list-style: none;
    padding: 0;
    margin: 0;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex: 1;
  }
  @media (min-width: 1024px) {
    .pk-header__nav { display: flex; }
  }
  .pk-header__nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: #6B6155;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s;
  }
  .pk-header__nav-link:hover,
  .pk-header__nav-link--active {
    color: var(--pk-brown);
  }

  /* Right actions */
  .pk-header__right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
    flex: 1;
  }
  @media (min-width: 768px) {
    .pk-header__right { gap: 1rem; }
  }
  .pk-header__icon {
    opacity: 0.7;
    transition: opacity 0.2s;
    display: flex;
    align-items: center;
    color: var(--pk-brown-dark);
  }
  .pk-header__icon:hover { opacity: 1; }
  .pk-header__icon--account { display: none; }
  @media (min-width: 640px) {
    .pk-header__icon--account { display: flex; }
  }
  .pk-header__cart {
    position: relative;
  }
  .pk-header__cart-badge {
    position: absolute;
    top: -2px;
    right: -2px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--pk-gold);
  }
  .pk-header__cta {
    display: none;
    padding: 0.5rem 1.25rem;
    font-size: 0.875rem;
  }
  @media (min-width: 640px) {
    .pk-header__cta { display: inline-flex; }
  }

  /* Mobile menu */
  .pk-mobile-menu {
    display: none;
    padding: 1rem 1.5rem 1.5rem;
    border-top: 1px solid var(--pk-warm-border-light);
  }
  .pk-mobile-menu.is-open { display: block; }
  @media (min-width: 768px) {
    .pk-mobile-menu { display: none; }
  }
  .pk-mobile-menu__nav {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
  }
  .pk-mobile-menu__link {
    display: block;
    padding: 0.75rem 0;
    font-size: 0.875rem;
    font-weight: 500;
    color: #6B6155;
    text-decoration: none;
    border-bottom: 1px solid var(--pk-warm-border-light);
    transition: color 0.2s;
  }
  .pk-mobile-menu__link:hover,
  .pk-mobile-menu__link--active {
    color: var(--pk-brown);
  }
  .pk-mobile-menu__cta {
    margin-top: 0.5rem;
  }

  header {
    height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  header a {
    position: relative;
    text-decoration: none;
    color: var(--color-foreground);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  header a sup {
    position: absolute;
    left: 100%;
    overflow: hidden;
    max-width: var(--page-margin);
  }
  header svg {
    width: 2rem;
  }
  header .header__menu,
  header .header__icons {
    display: flex;
    gap: 1rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Open The Gallery"
    }
  ]
}
{% endschema %}
