{% doc %}
  Renders BreadcrumbList JSON-LD structured data for product pages.

  Product JSON-LD is already handled by `meta-tags.liquid` via `product | structured_data`.
  This snippet supplements it with breadcrumb navigation data for Google search results.

  @example
  {% render 'product-json-ld' %}
{% enddoc %}

{%- if request.page_type == 'product' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ shop.url }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Shop",
      "item": "{{ shop.url }}"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ product.title | json }},
      "item": "{{ shop.url }}{{ product.url }}"
    }
  ]
}
</script>
{%- endif -%}
