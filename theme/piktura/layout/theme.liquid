<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% comment %} Google Fonts: Inter, Playfair Display, Space Grotesk {% endcomment %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">

    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {% # BreadcrumbList structured data for product pages %}
    {% render 'product-json-ld' %}

    {{ content_for_header }}
    <script src="{{ 'piktura-global.js' | asset_url }}" defer></script>
  </head>

  <body>
    {% unless template == 'product' %}
      {% sections 'header-group' %}
    {% endunless %}

    <main id="MainContent" {% unless template == 'product' %}style="padding-top: 64px;"{% endunless %}>
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}
  </body>
</html>
