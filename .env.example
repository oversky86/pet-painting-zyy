# ===== Frontend (frontend/.env.local) =====
NEXT_PUBLIC_SHOP_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_STOREFRONT_TOKEN=<Storefront API public token>
NEXT_PUBLIC_APP_URL=https://your-app.com

# ===== App (app/ecommerce-pet-app/.env) =====
SHOPIFY_API_KEY=<App Client ID>
SHOPIFY_API_SECRET=<App Secret>
SHOPIFY_APP_URL=<App public URL>
SCOPES=write_products,write_metaobjects,write_metaobject_definitions,read_orders,write_orders
DATABASE_URL=file:dev.sqlite
REPLICATE_API_TOKEN=<Replicate API token>
REPLICATE_MODEL_VERSION=<nano-banana version hash>
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=<Supabase service role key>
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60
